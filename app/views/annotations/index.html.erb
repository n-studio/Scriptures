<div class="h-full overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto w-full">
  <div class="flex items-center justify-between mb-8">
    <h1 class="font-bold text-2xl">Annotations</h1>
  </div>

  <%# Filters %>
  <div class="flex flex-wrap items-center gap-2 mb-6 text-xs">
    <%= form_with url: annotations_path(user_id: current_user), method: :get, class: "flex items-center gap-2" do |f| %>
      <%= f.hidden_field :user_id, value: current_user.id %>
      <%= f.text_field :q, value: params[:q], placeholder: "Search annotations...", class: "rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-2 py-1 text-xs w-48 focus:outline-none focus:ring-1 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      <%= f.submit "Search", class: "px-2 py-1 rounded-md bg-stone-200 dark:bg-stone-800 font-medium cursor-pointer hover:bg-stone-300 dark:hover:bg-stone-700 transition-colors" %>
    <% end %>
    <% if @tags.any? %>
      <div class="h-4 w-px bg-stone-200 dark:bg-stone-800 mx-1"></div>
      <% @tags.each do |tag| %>
        <%= link_to tag.name, annotations_path(user_id: current_user, tag: tag.name),
              class: "px-2 py-0.5 rounded-full border border-stone-300 dark:border-stone-700 hover:bg-stone-100 dark:hover:bg-stone-900 transition-colors #{params[:tag] == tag.name ? 'bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 border-transparent' : ''}" %>
      <% end %>
    <% end %>
  </div>

  <% if @annotations.any? %>
    <div class="space-y-4">
      <% @annotations.each do |annotation| %>
        <% passage = annotation.passage %>
        <% scripture = annotation.scripture %>
        <% corpus = scripture.corpus %>
        <div class="p-4 border border-stone-200 dark:border-stone-800 rounded-xl">
          <div class="flex items-start justify-between mb-2">
            <%= link_to reading_path(corpus_slug: corpus.slug, scripture_slug: scripture.slug, division_number: passage.division.number),
                  class: "text-xs font-bold text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 uppercase tracking-wider" do %>
              <%= scripture.name %> <%= passage.division.number %>:<%= passage.number %>
            <% end %>
            <div class="flex items-center gap-2">
              <%= button_to annotation_path(annotation), method: :delete, class: "text-xs text-red-500 hover:underline", data: { turbo_confirm: "Delete annotation?" } do %>
                Delete
              <% end %>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-stone-700 dark:text-stone-300"><%= annotation.body %></p>
          <% if annotation.tags.any? %>
            <div class="flex flex-wrap gap-1 mt-2">
              <% annotation.tags.each do |tag| %>
                <span class="px-2 py-0.5 rounded-full text-[10px] font-medium bg-stone-100 dark:bg-stone-800 text-stone-600 dark:text-stone-400"><%= tag.name %></span>
              <% end %>
            </div>
          <% end %>
          <div class="text-[10px] text-stone-400 mt-2"><%= time_ago_in_words(annotation.created_at) %> ago</div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-500 text-sm">No annotations yet. Add notes to passages from the reading view.</p>
  <% end %>
</div>
