<%= turbo_stream_from "llm_translations_#{@division.id}" %>

<div class="dashboard">
  <%# Header %>
  <div class="dashboard__header flex items-center justify-between">
    <div>
      <nav class="text-sm text-slate-500 dark:text-slate-400 mb-1 flex items-center gap-1.5">
        <%= link_to "Corpora", admin_llm_translations_path, class: "hover:text-slate-900 dark:hover:text-slate-100" %>
        <span>/</span>
        <%= link_to @corpus.name, admin_llm_translations_path(corpus_id: @corpus.id), class: "hover:text-slate-900 dark:hover:text-slate-100" %>
        <span>/</span>
        <%= link_to @scripture.name, admin_llm_translations_path(scripture_id: @scripture.id, style: @style), class: "hover:text-slate-900 dark:hover:text-slate-100" %>
      </nav>
      <h1 class="dashboard__title"><%= @division.display_name %></h1>
    </div>

    <%= button_to "Translate All", translate_admin_llm_translations_path(division_id: @division.id, style: @style, provider: @provider),
          method: :post,
          class: "px-4 py-2 text-sm font-medium rounded-lg bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-200 transition-colors cursor-pointer" %>
  </div>

  <%= render partial: "admin/application/notice", locals: { notice: } %>
  <%= render partial: "admin/application/alert", locals: { alert: } %>

  <%# Style tabs + provider selector %>
  <div class="flex items-center justify-between mb-6">
    <div class="flex gap-2">
      <% LlmTranslationJob::STYLES.each do |key, config| %>
        <%= link_to config[:name_suffix],
              admin_llm_translation_path(@division, style: key, provider: @provider),
              class: "px-3 py-1.5 text-xs font-medium rounded-md transition-colors #{@style == key ? 'bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900' : 'bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-600'}" %>
      <% end %>
    </div>

    <div class="flex items-center gap-2">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">Provider</label>
      <select data-controller="provider-select"
              data-action="change->provider-select#navigate"
              data-provider-select-url-value="<%= admin_llm_translation_path(@division, style: @style) %>"
              class="text-xs rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-700 dark:text-slate-300 px-2 py-1.5">
        <% LlmTranslationJob::PROVIDERS.each do |key, config| %>
          <option value="<%= key %>" <%= "selected" if @provider == key %>><%= config[:name] %></option>
        <% end %>
      </select>
    </div>
  </div>

  <%# Column headers %>
  <div class="grid grid-cols-[1fr_auto_1fr] gap-4 mb-3 px-1">
    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
      Original<%= " (#{@source_translation.abbreviation})" if @source_translation %>
    </span>
    <span class="w-10"></span>
    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
      <%= @style_config[:name_suffix] %> (LLM-<%= @style_config[:abbreviation_suffix] %>)
    </span>
  </div>

  <%# Passage rows %>
  <div class="space-y-3">
    <% @passages.each do |passage| %>
      <% original_text = @originals[passage.id] %>
      <% translated_text = @translations[passage.id] %>

      <div class="grid grid-cols-[1fr_auto_1fr] gap-4 items-start bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4">

        <%# Original text (left) %>
        <div>
          <span class="text-[11px] font-bold text-slate-400 dark:text-slate-500"><%= passage.number %></span>
          <% if original_text.present? %>
            <p class="text-sm text-slate-700 dark:text-slate-300 mt-0.5 leading-relaxed"><%= original_text %></p>
          <% else %>
            <p class="text-sm text-slate-400 dark:text-slate-500 italic mt-0.5">No original text available</p>
          <% end %>
        </div>

        <%# Translate button (center) %>
        <div class="flex flex-col items-center gap-2 pt-4">
          <%= button_to translate_admin_llm_translations_path(
                division_id: @division.id, passage_id: passage.id, style: @style, provider: @provider
              ), method: :post, class: "w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 hover:bg-blue-100 hover:text-blue-600 dark:hover:bg-blue-900 dark:hover:text-blue-400 transition-colors cursor-pointer" do %>
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>

        <%# Translation textarea + save (right) %>
        <div>
          <span class="text-[11px] font-bold text-slate-400 dark:text-slate-500"><%= passage.number %></span>
          <%= form_tag save_passage_admin_llm_translations_path, method: :patch, class: "mt-0.5" do %>
            <%= hidden_field_tag :passage_id, passage.id %>
            <%= hidden_field_tag :style, @style %>
            <div id="passage_<%= passage.id %>_translation">
              <textarea name="text"
                        rows="<%= [ (original_text.to_s.length / 80.0).ceil + 1, 3 ].max %>"
                        class="w-full text-sm rounded-md border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-700/50 text-slate-700 dark:text-slate-300 px-3 py-2 leading-relaxed resize-y focus:ring-1 focus:ring-blue-500 focus:border-blue-500"><%= translated_text %></textarea>
            </div>
            <div class="flex justify-end mt-1.5">
              <%= submit_tag "Save", class: "px-3 py-1 text-xs font-medium rounded-md bg-emerald-600 text-white hover:bg-emerald-700 transition-colors cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
