<div class="h-full overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-5xl mx-auto w-full">
  <%# Breadcrumb %>
  <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-widest mb-8">
    <%= link_to "Browse", traditions_path, class: "hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
    <%= chevron_right_icon %>
    <span class="text-stone-900 dark:text-stone-100"><%= @tradition.name %></span>
  </div>

  <div class="mb-12">
    <h2 class="text-3xl font-serif mb-2"><%= @tradition.name %></h2>
    <p class="text-stone-500 text-sm"><%= @tradition.description %></p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @corpora.each do |corpus| %>
      <%= link_to tradition_corpora_path(@tradition, corpus.slug), class: "p-6 border border-stone-200 dark:border-stone-800 rounded-2xl hover:border-blue-500 transition-colors group" do %>
        <h3 class="font-bold text-lg mb-2 group-hover:text-blue-500 transition-colors"><%= corpus.name %></h3>
        <p class="text-sm text-stone-500 mb-4 line-clamp-2"><%= corpus.description %></p>
        <div class="flex items-center gap-2 text-[10px] font-bold text-stone-400 uppercase tracking-widest">
          <span><%= pluralize(corpus.scriptures.size, "book") %></span>
          <%= arrow_right_icon %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
