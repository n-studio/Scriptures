<div class="flex items-center justify-center h-full p-8">
  <div class="w-full max-w-sm">
    <% if alert = flash[:alert] %>
      <p class="py-2 px-3 bg-red-50 dark:bg-red-950 mb-5 text-red-600 dark:text-red-400 text-sm font-medium rounded-lg"><%= alert %></p>
    <% end %>

    <h1 class="font-bold text-2xl mb-1">Check your email</h1>
    <p class="text-stone-500 dark:text-stone-400 text-sm mb-6">Enter the 6-character code from your email, or click the link in the email to sign in from any device.</p>

    <%= form_with url: session_verification_path, method: :post, class: "space-y-4" do |form| %>
      <div>
        <%= form.text_field :code, required: true, autofocus: true, autocomplete: "one-time-code", maxlength: 6, placeholder: "ABC123", class: "block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-center text-2xl font-mono font-bold tracking-[0.3em] uppercase focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      </div>

      <%= form.submit "Verify code", class: "w-full rounded-lg px-3 py-2.5 bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 text-sm font-medium cursor-pointer hover:bg-stone-800 dark:hover:bg-stone-200 transition-colors" %>
    <% end %>

    <p class="text-center text-stone-400 dark:text-stone-500 text-xs mt-6">
      Didn't get the email? <%= link_to "Try again", new_session_path, class: "text-stone-600 dark:text-stone-300 hover:underline" %>
    </p>
  </div>
</div>
