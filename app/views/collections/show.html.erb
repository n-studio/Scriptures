<div class="h-full overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto w-full">
  <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-widest mb-8">
    <%= link_to "Collections", collections_path, class: "hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
    <%= chevron_right_icon %>
    <span class="text-stone-900 dark:text-stone-100"><%= @collection.name %></span>
  </div>

  <div class="mb-8">
    <h1 class="font-bold text-2xl mb-2"><%= @collection.name %></h1>
    <% if @collection.description.present? %>
      <p class="text-stone-500 text-sm"><%= @collection.description %></p>
    <% end %>
    <div class="flex items-center gap-3 mt-3 text-xs text-stone-400">
      <span><%= pluralize(@collection_passages.size, "passage") %></span>
      <% if @collection.public? %>
        <span class="px-1.5 py-0.5 rounded bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 font-medium">Public</span>
      <% end %>
      <%= link_to "Export PDF", export_collection_path(@collection, format: :pdf), class: "text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
    </div>
  </div>

  <% if @collection_passages.any? %>
    <div class="space-y-3">
      <% @collection_passages.each do |cp| %>
        <% passage = cp.passage %>
        <% scripture = passage.division.scripture %>
        <% corpus = scripture.corpus %>
        <div class="flex items-center justify-between p-4 border border-stone-200 dark:border-stone-800 rounded-xl hover:border-stone-400 dark:hover:border-stone-600 transition-colors">
          <%= link_to reading_path(corpus_slug: corpus.slug, scripture_slug: scripture.slug, division_number: passage.division.number),
                class: "flex-1" do %>
            <div class="font-medium"><%= scripture.name %> <%= passage.division.number %>:<%= passage.number %></div>
            <div class="text-xs text-stone-500 mt-0.5"><%= corpus.name %></div>
          <% end %>
          <% if authenticated? && @collection.user == current_user %>
            <%= button_to collections_passage_path(id: passage.id, collection_id: @collection.id, passage_id: passage.id), method: :delete, class: "text-xs text-red-500 hover:underline ml-4" do %>
              Remove
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-500 text-sm">No passages in this collection yet. Add passages from the reading view.</p>
  <% end %>
</div>
