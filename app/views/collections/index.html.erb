<div class="h-full overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto w-full">
  <div class="flex items-center justify-between mb-8">
    <h1 class="font-bold text-2xl">Collections</h1>
  </div>

  <%# New collection form %>
  <%= form_with model: Collection.new, url: collections_path, class: "flex items-center gap-2 mb-8" do |f| %>
    <%= f.text_field :name, placeholder: "New collection name...", required: true, class: "flex-1 rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
    <%= f.submit "Create", class: "rounded-lg px-4 py-2 bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 text-sm font-medium cursor-pointer hover:bg-stone-800 dark:hover:bg-stone-200 transition-colors" %>
  <% end %>

  <% if @collections.any? %>
    <div class="space-y-3">
      <% @collections.each do |collection| %>
        <div class="flex items-center justify-between p-4 border border-stone-200 dark:border-stone-800 rounded-xl hover:border-stone-400 dark:hover:border-stone-600 transition-colors">
          <%= link_to collection_path(collection), class: "flex-1" do %>
            <div class="font-medium"><%= collection.name %></div>
            <div class="text-xs text-stone-500 mt-0.5">
              <%= pluralize(collection.passages.size, "passage") %>
              <% if collection.public? %>
                <span class="ml-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300">Public</span>
              <% end %>
            </div>
          <% end %>
          <%= button_to collection_path(collection), method: :delete, class: "text-xs text-red-500 hover:underline ml-4", data: { turbo_confirm: "Delete collection?" } do %>
            Delete
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-500 text-sm">No collections yet. Create one to start curating passage sets.</p>
  <% end %>
</div>
