<div class="h-full overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto w-full">
  <h1 class="font-bold text-2xl mb-8">Bookmarks</h1>

  <% if @bookmarks.any? %>
    <div class="space-y-3">
      <% @bookmarks.each do |bookmark| %>
        <% passage = bookmark.passage %>
        <% scripture = bookmark.scripture %>
        <% corpus = scripture.corpus %>
        <div class="flex items-center justify-between p-4 border border-stone-200 dark:border-stone-800 rounded-xl hover:border-stone-400 dark:hover:border-stone-600 transition-colors">
          <%= link_to reading_path(corpus_slug: corpus.slug, scripture_slug: scripture.slug, division_number: passage.division.number),
                class: "flex-1" do %>
            <div class="font-medium"><%= scripture.name %> <%= passage.division.number %>:<%= passage.number %></div>
            <div class="text-xs text-stone-500 mt-0.5"><%= corpus.name %></div>
          <% end %>
          <%= button_to bookmark_path(bookmark), method: :delete, class: "text-xs text-red-500 hover:underline ml-4", data: { turbo_confirm: "Remove bookmark?" } do %>
            Remove
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-500 text-sm">No bookmarks yet. Bookmark passages from the reading view.</p>
  <% end %>
</div>
