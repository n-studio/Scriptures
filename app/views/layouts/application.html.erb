<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Scriptures" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Scriptures">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme sidebar">
    <div class="flex h-screen w-screen overflow-hidden bg-stone-50 dark:bg-stone-950 text-stone-900 dark:text-stone-100">
      <%# Mobile Sidebar Overlay %>
      <div data-sidebar-target="overlay"
           data-action="click->sidebar#toggle"
           style="display: none"
           class="fixed inset-0 bg-black/50 z-40 md:hidden"></div>

      <%# Sidebar %>
      <aside data-sidebar-target="sidebar"
             class="fixed md:relative h-full w-64 border-r border-stone-200 dark:border-stone-800 flex flex-col z-50 bg-white dark:bg-stone-950 -translate-x-full md:translate-x-0 transition-all duration-300 overflow-hidden">
        <div class="p-6 flex items-center gap-3">
          <div class="w-8 h-8 bg-stone-900 dark:bg-stone-100 rounded-lg flex items-center justify-center text-white dark:text-stone-900 font-bold shrink-0">S</div>
          <h1 data-sidebar-target="label" class="font-bold text-lg tracking-tight whitespace-nowrap">Scriptures</h1>
        </div>

        <nav class="flex-1 px-3 space-y-1 overflow-y-auto">
          <%= sidebar_link "Reading", reading_icon, root_path, active: current_page?(root_path) || controller_name == "passages" %>
          <%= sidebar_link "Browse", browse_icon, traditions_path, active: controller_name.in?(%w[traditions corpora scriptures divisions]) %>
          <%= sidebar_link "Search", search_icon, search_path, active: controller_name == "search" %>
          <% if authenticated? %>
            <div class="mt-4 mb-1 px-3"><div class="border-t border-stone-100 dark:border-stone-900"></div></div>
            <%= sidebar_link "Bookmarks", bookmark_icon(size: 20), bookmarks_path, active: controller_name == "bookmarks" %>
            <%= sidebar_link "Annotations", annotation_icon, annotations_path(user_id: current_user), active: controller_name == "annotations" %>
            <%= sidebar_link "Collections", collection_icon, collections_path, active: controller_name == "collections" %>
            <%= sidebar_link "Curricula", curriculum_icon, curricula_path, active: controller_name == "curricula" %>
          <% end %>
        </nav>

        <div class="p-4 border-t border-stone-100 dark:border-stone-900 space-y-2">
          <button data-action="theme#toggle"
                  class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-stone-500 hover:bg-stone-50 dark:hover:bg-stone-900/50 transition-all">
            <span data-theme-target="icon"><%= sun_icon %></span>
            <span data-sidebar-target="label" class="text-sm font-medium whitespace-nowrap" data-theme-target="label">Light Mode</span>
          </button>
        </div>
      </aside>

      <%# Main Content %>
      <main class="flex-1 flex flex-col overflow-hidden relative">
        <%# Top Header %>
        <header class="h-16 border-b border-stone-200 dark:border-stone-800 flex items-center justify-between px-4 md:px-8 bg-white/50 dark:bg-stone-950/50 backdrop-blur-md z-30 shrink-0">
          <div class="flex items-center gap-2 md:gap-4 flex-1">
            <button data-action="sidebar#toggle"
                    class="p-2 hover:bg-stone-100 dark:hover:bg-stone-900 rounded-lg transition-colors">
              <%= menu_icon %>
            </button>
            <div class="h-8 w-px bg-stone-200 dark:border-stone-800 mx-1 md:mx-2 hidden md:block"></div>
            <div class="flex items-center gap-2 text-stone-400 flex-1 md:flex-none">
              <%= search_icon_sm %>
              <%= form_with url: search_path, method: :get, class: "flex-1 md:flex-none" do |f| %>
                <%= f.text_field :q, placeholder: "Search corpus, words...", class: "bg-transparent border-none focus:ring-0 text-sm w-full md:w-64 text-stone-900 dark:text-stone-100 placeholder:text-stone-400 outline-none" %>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <% if authenticated? %>
              <%= link_to account_path, class: "p-2 hover:bg-stone-100 dark:hover:bg-stone-900 rounded-lg transition-colors text-stone-500 hover:text-stone-900 dark:hover:text-stone-100" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-5.5-2.5a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0zM10 12a5.99 5.99 0 00-4.793 2.39A6.483 6.483 0 0010 16.5a6.483 6.483 0 004.793-2.11A5.99 5.99 0 0010 12z" clip-rule="evenodd" /></svg>
              <% end %>
            <% else %>
              <%= link_to "Sign in", new_session_path, class: "text-sm text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
            <% end %>
          </div>
        </header>

        <%# Screen Content %>
        <div class="flex-1 overflow-hidden">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
