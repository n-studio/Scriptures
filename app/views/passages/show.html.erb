<div class="flex h-full overflow-hidden relative" data-controller="commentary">
  <div class="flex-1 flex flex-col overflow-hidden">
    <%# Breadcrumb + Navigation %>
    <div class="px-4 md:px-8 py-3 flex items-center justify-between border-b border-stone-200 dark:border-stone-800">
      <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-widest overflow-x-auto whitespace-nowrap">
        <%= link_to @tradition.name, tradition_path(@tradition), class: "hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
        <%= chevron_right_icon %>
        <%= link_to @corpus.name, tradition_corpora_path(@tradition, @corpus.slug), class: "hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
        <%= chevron_right_icon %>
        <span class="text-stone-900 dark:text-stone-100"><%= @scripture.name %> <%= @division.number %></span>
      </div>
      <div class="flex items-center gap-1">
        <button data-action="commentary#toggle"
                class="md:hidden p-2 text-stone-500 hover:text-stone-900 dark:hover:text-stone-100">
          <%= info_icon %>
        </button>
      </div>
    </div>

    <%# Toolbar: translation switcher, view modes, jump-to-reference %>
    <div class="px-4 md:px-8 py-2 border-b border-stone-200 dark:border-stone-800 flex flex-wrap items-center gap-2 md:gap-4 text-xs">
      <%# Translation selector grouped by edition type %>
      <% grouped = @translations.group_by { |t| t.edition_type || "other" } %>
      <% %w[original critical devotional other].each do |type| %>
        <% next unless (group = grouped[type]) %>
        <% group.each do |t| %>
          <% selected = @selected_translations.include?(t) %>
          <%= link_to reading_path(corpus_slug: @corpus.slug, scripture_slug: @scripture.slug, division_number: @division.number, t: toggle_translation_params(t), parallel: params[:parallel], diff: params[:diff]),
                class: "px-2 py-1 rounded-md font-medium transition-colors #{selected ? 'bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900' : 'text-stone-500 hover:bg-stone-100 dark:hover:bg-stone-900'}",
                title: "#{t.name} (#{t.edition_type || 'unclassified'})",
                data: { turbo_action: "replace" } do %>
            <%= t.abbreviation %><% if t.edition_type %><span class="ml-0.5 text-[8px] align-super <%= edition_type_color(t.edition_type) %>"><%= edition_type_badge(t.edition_type) %></span><% end %>
          <% end %>
        <% end %>
        <% if type != "other" && grouped.keys.last != type %>
          <div class="h-4 w-px bg-stone-200 dark:bg-stone-800 mx-0.5 hidden md:block"></div>
        <% end %>
      <% end %>

      <div class="h-4 w-px bg-stone-200 dark:border-stone-800 mx-1 hidden md:block"></div>

      <%# View mode toggles %>
      <% base_params = { corpus_slug: @corpus.slug, scripture_slug: @scripture.slug, division_number: @division.number, t: params[:t] } %>
      <%= link_to "Parallel", reading_path(**base_params, parallel: @parallel ? nil : "1"),
            class: "px-2 py-1 rounded-md font-medium transition-colors #{@parallel ? 'bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900' : 'text-stone-500 hover:bg-stone-100 dark:hover:bg-stone-900'}",
            data: { turbo_action: "replace" } %>
      <%= link_to "Diff", reading_path(**base_params, diff: params[:diff].present? ? nil : "1"),
            class: "px-2 py-1 rounded-md font-medium transition-colors #{params[:diff].present? ? 'bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900' : 'text-stone-500 hover:bg-stone-100 dark:hover:bg-stone-900'}",
            data: { turbo_action: "replace" } %>

      <%# Jump-to-reference %>
      <div class="ml-auto">
        <%= form_with url: jump_path, method: :get, class: "flex items-center gap-1" do |f| %>
          <%= f.text_field :ref, placeholder: "John 3:16", class: "w-28 md:w-36 rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-stone-900 dark:focus:ring-stone-100", autocomplete: "off" %>
          <%= f.submit "Go", class: "px-2 py-1 rounded-md bg-stone-200 dark:bg-stone-800 text-stone-700 dark:text-stone-300 font-medium cursor-pointer hover:bg-stone-300 dark:hover:bg-stone-700 transition-colors" %>
        <% end %>
      </div>
    </div>

    <%# Flash %>
    <% if flash[:alert] %>
      <div class="px-4 md:px-8 py-2 bg-red-50 dark:bg-red-950 text-red-600 dark:text-red-400 text-sm"><%= flash[:alert] %></div>
    <% end %>

    <%# Content: Standard, Parallel, or Diff view %>
    <div class="flex-1 overflow-y-auto px-4 md:px-8 py-8 md:py-12 max-w-5xl mx-auto w-full">
      <% if @diff_left && @diff_right %>
        <%# === DIFF VIEW === %>
        <div class="mb-6 text-xs text-stone-500 font-medium">
          Comparing <span class="text-stone-900 dark:text-stone-100"><%= @diff_left.abbreviation %></span>
          vs <span class="text-stone-900 dark:text-stone-100"><%= @diff_right.abbreviation %></span>
        </div>
        <div class="space-y-8">
          <% @passages.each do |passage| %>
            <div class="flex gap-4">
              <span class="text-xs font-mono text-stone-400 mt-1 w-4 shrink-0"><%= passage.number %></span>
              <div class="flex-1 text-base leading-relaxed">
                <% left_text = passage.text_for(@diff_left) %>
                <% right_text = passage.text_for(@diff_right) %>
                <% if left_text.present? && right_text.present? %>
                  <% translation_diff(left_text, right_text).each do |change| %>
                    <% case change[:type] %>
                    <% when :equal %>
                      <span><%= change[:text] %> </span>
                    <% when :deletion %>
                      <span class="bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 line-through px-0.5 rounded"><%= change[:text] %> </span>
                    <% when :addition %>
                      <span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-0.5 rounded"><%= change[:text] %> </span>
                    <% when :change %>
                      <span class="bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 line-through px-0.5 rounded"><%= change[:old_text] %> </span>
                      <span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-0.5 rounded"><%= change[:new_text] %> </span>
                    <% end %>
                  <% end %>
                <% else %>
                  <span class="text-stone-400 italic">No text available for both translations.</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

      <% elsif @parallel %>
        <%# === PARALLEL VIEW === %>
        <%# Mobile: swipe indicator %>
        <div class="md:hidden flex items-center justify-center gap-1.5 mb-4" data-controller="parallel-swipe">
          <% @selected_translations.each_with_index do |t, i| %>
            <button data-parallel-swipe-target="indicator"
                    data-action="click->parallel-swipe#goTo"
                    data-parallel-swipe-index-param="<%= i %>"
                    class="w-2 h-2 rounded-full transition-colors <%= i == 0 ? 'bg-stone-900 dark:bg-stone-100' : 'bg-stone-300 dark:bg-stone-700' %>"
                    title="<%= t.abbreviation %>"></button>
          <% end %>
        </div>

        <div class="space-y-6">
          <% @passages.each do |passage| %>
            <% texts = @selected_translations.map { |t| passage.text_for(t) } %>
            <% has_missing = texts.any?(&:blank?) && texts.any?(&:present?) %>
            <% has_variants = passage.textual_variants.any? %>
            <div class="flex gap-4 <%= 'border-l-2 border-amber-400 pl-2' if has_missing %>" data-controller="parallel-swipe">
              <div class="flex flex-col items-center gap-1">
                <span class="text-xs font-mono text-stone-400 mt-1 w-4 shrink-0"><%= passage.number %></span>
                <% if has_variants %>
                  <span class="w-4 text-center text-[8px] text-purple-500" title="Textual variants exist">V</span>
                <% end %>
              </div>
              <%# Mobile: horizontal scroll with snap; Desktop: grid columns %>
              <div data-parallel-swipe-target="container"
                   data-action="touchstart->parallel-swipe#touchstart touchmove->parallel-swipe#touchmove touchend->parallel-swipe#touchend"
                   class="flex-1 flex md:grid md:grid-cols-<%= [@selected_translations.size, 4].min %> gap-4 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory scroll-smooth"
                   style="-webkit-overflow-scrolling: touch;">
                <% @selected_translations.each_with_index do |t, i| %>
                  <div class="min-w-full md:min-w-0 snap-start">
                    <div class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1"><%= t.abbreviation %></div>
                    <% if texts[i].present? %>
                      <% is_rtl = t.language.in?(%w[Hebrew Arabic]) %>
                      <p class="text-sm leading-relaxed text-stone-700 dark:text-stone-300 <%= 'rtl text-right' if is_rtl %>"><%= texts[i] %></p>
                    <% else %>
                      <p class="text-sm text-amber-500 dark:text-amber-400 italic">Not present in this version</p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

      <% else %>
        <%# === STANDARD VIEW === %>
        <div class="space-y-8 md:space-y-12">
          <% @passages.each do |passage| %>
            <div class="group relative" data-controller="word-tooltip passage-actions">
              <div class="flex flex-col md:flex-row gap-2 md:gap-6">
                <span class="text-xs font-mono text-stone-400 mt-2 w-4 shrink-0"><%= passage.number %></span>
                <div class="space-y-4 flex-1">
                  <% @selected_translations.each_with_index do |t, i| %>
                    <% text = passage.text_for(t) %>
                    <% next unless text %>
                    <% is_rtl = t.language.in?(%w[Hebrew Arabic]) %>
                    <% if i == 0 %>
                      <%# Primary text with source criticism coloring %>
                      <% source = passage.source_documents.first %>
                      <% source_color = source_text_class(source&.color) %>
                      <p class="scripture-text text-2xl md:text-3xl <%= source_color %> <%= 'rtl text-right' if is_rtl %>">
                        <% text.split(/\s+/).each do |word| %>
                          <span class="hover:bg-stone-200 dark:hover:bg-stone-800 px-1 rounded cursor-help transition-colors inline-block"
                                data-action="mouseenter->word-tooltip#show mouseleave->word-tooltip#hide"
                                data-word="<%= word %>"><%= word %> </span>
                        <% end %>
                      </p>
                    <% else %>
                      <p class="scripture-text text-base md:text-lg text-stone-600 dark:text-stone-400 <%= 'rtl text-right' if is_rtl %>">
                        <%= text %>
                      </p>
                    <% end %>
                  <% end %>
                  <%# Passage action buttons (bookmark, annotate, collect) %>
                  <% if authenticated? %>
                    <div class="flex items-center gap-2 mt-2 opacity-0 group-hover:opacity-100 transition-opacity">
                      <% if @bookmarked_ids.include?(passage.id) %>
                        <%= button_to bookmark_path(current_user.bookmarks.find_by(passage: passage)), method: :delete, class: "text-xs text-amber-500 hover:text-amber-600 transition-colors", title: "Remove bookmark" do %>
                          <%= bookmark_icon(size: 14) %>
                        <% end %>
                      <% else %>
                        <%= button_to bookmarks_path(passage_id: passage.id), class: "text-xs text-stone-400 hover:text-amber-500 transition-colors", title: "Bookmark" do %>
                          <%= bookmark_icon(size: 14) %>
                        <% end %>
                      <% end %>

                      <button data-action="click->passage-actions#toggleAnnotation"
                              data-passage-id="<%= passage.id %>"
                              class="text-xs text-stone-400 hover:text-blue-500 transition-colors" title="Annotate">
                        <%= annotation_icon(size: 14) %>
                      </button>

                      <% if @user_collections.any? %>
                        <details class="relative">
                          <summary class="text-xs text-stone-400 hover:text-green-500 transition-colors cursor-pointer list-none" title="Add to collection">
                            <%= collection_icon(size: 14) %>
                          </summary>
                          <div class="absolute left-0 top-6 z-10 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-700 rounded-lg shadow-lg py-1 min-w-40">
                            <% @user_collections.each do |col| %>
                              <%= button_to add_passage_collection_path(col, passage_id: passage.id), class: "w-full text-left px-3 py-1.5 text-xs hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors" do %>
                                <%= col.name %>
                              <% end %>
                            <% end %>
                          </div>
                        </details>
                      <% end %>
                    </div>
                  <% end %>

                  <%# Inline annotations %>
                  <% if (annotations = @user_annotations[passage.id]) %>
                    <% annotations.each do |ann| %>
                      <div class="mt-2 pl-3 border-l-2 border-blue-300 dark:border-blue-700">
                        <p class="text-xs text-stone-600 dark:text-stone-400"><%= ann.body %></p>
                        <% if ann.tags.any? %>
                          <div class="flex gap-1 mt-1">
                            <% ann.tags.each do |tag| %>
                              <span class="px-1.5 py-0.5 rounded text-[9px] font-medium bg-stone-100 dark:bg-stone-800 text-stone-500"><%= tag.name %></span>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Prev/Next Navigation %>
    <div class="px-4 md:px-8 py-3 border-t border-stone-200 dark:border-stone-800 flex items-center justify-between">
      <div>
        <% if @prev_division %>
          <%= link_to reading_path(corpus_slug: @corpus.slug, scripture_slug: @scripture.slug, division_number: @prev_division.number, t: params[:t], parallel: params[:parallel], diff: params[:diff]),
                class: "flex items-center gap-1 text-sm text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 transition-colors" do %>
            <%= chevron_left_icon %> Chapter <%= @prev_division.number %>
          <% end %>
        <% end %>
      </div>

      <%# Source Criticism Legend %>
      <% if @source_documents.any? && !@parallel && !@diff_left %>
        <div class="hidden md:flex items-center gap-4 text-[10px] font-bold uppercase tracking-widest text-stone-500">
          <% @source_documents.each do |sd| %>
            <div class="flex items-center gap-1.5">
              <div class="w-2.5 h-2.5 <%= source_bg_class(sd.color) %> rounded-sm"></div>
              <span><%= sd.abbreviation %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <div>
        <% if @next_division %>
          <%= link_to reading_path(corpus_slug: @corpus.slug, scripture_slug: @scripture.slug, division_number: @next_division.number, t: params[:t], parallel: params[:parallel], diff: params[:diff]),
                class: "flex items-center gap-1 text-sm text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 transition-colors" do %>
            Chapter <%= @next_division.number %> <%= chevron_right_icon(size: 12) %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Right Sidebar - Commentary %>
  <div data-commentary-target="panel"
       class="flex absolute md:relative right-0 top-0 h-full z-40 w-80 border-l border-stone-200 dark:border-stone-800 flex-col bg-white/80 dark:bg-stone-950/80 backdrop-blur-xl">
    <div class="p-4 border-b border-stone-200 dark:border-stone-800 flex justify-between items-center">
      <h3 class="text-xs font-bold uppercase tracking-widest">Commentary</h3>
      <button data-action="commentary#toggle" class="md:hidden p-1">
        <%= x_icon %>
      </button>
    </div>
    <div class="p-6 overflow-y-auto space-y-6">
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold text-stone-400"><%= @scripture.name.upcase %> <%= @division.number %>:1</span>
          <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">Redaction</span>
        </div>
        <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-400">
          The opening phrase <span class="italic font-serif">bereshit</span> is grammatically ambiguous. Scholars debate whether it represents an absolute beginning or a temporal clause ("When God began to create...").
        </p>
      </div>
      <div class="pt-4 border-t border-stone-100 dark:border-stone-900">
        <p class="text-[10px] text-stone-400 italic">Source: Speiser, E.A. (1964). Genesis (Anchor Bible).</p>
      </div>
    </div>
  </div>
</div>
