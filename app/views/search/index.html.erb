<div class="flex h-full">
  <%# Results %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="px-4 md:px-8 py-4 border-b border-stone-200 dark:border-stone-800 flex items-center gap-4">
      <% if @query.present? %>
        <span class="text-sm">Results for <span class="font-bold">"<%= @query %>"</span></span>
        <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-stone-100 text-stone-800 dark:bg-stone-800 dark:text-stone-300">
          <%= pluralize(@results.size, "result") %>
        </span>
      <% else %>
        <span class="text-sm text-stone-500">Enter a search term above to search across all scriptures.</span>
      <% end %>
    </div>

    <div class="flex-1 overflow-y-auto p-4 md:p-8 space-y-6">
      <% if @query.present? && @results.empty? %>
        <p class="text-stone-400 text-sm">No results found for "<%= @query %>".</p>
      <% end %>

      <% @results.group_by { |pt| pt.passage.division.scripture.corpus }.each do |corpus, pts| %>
        <section class="space-y-6">
          <div class="flex items-center gap-4">
            <h3 class="text-xs font-bold uppercase tracking-widest text-stone-400"><%= corpus.tradition.name %> / <%= corpus.name %></h3>
            <div class="h-px flex-1 bg-stone-100 dark:bg-stone-900"></div>
          </div>

          <div class="space-y-4">
            <% pts.each do |pt| %>
              <% passage = pt.passage %>
              <% division = passage.division %>
              <% scripture = division.scripture %>
              <%= link_to reading_path(corpus_slug: corpus.slug, scripture_slug: scripture.slug, division_number: division.number),
                    class: "block space-y-1 group" do %>
                <div class="flex items-center gap-2 text-[10px] font-bold text-stone-400 group-hover:text-blue-500 transition-colors">
                  <span><%= scripture.name.upcase %> <%= division.number %>:<%= passage.number %></span>
                  <%= chevron_right_icon %>
                  <span><%= pt.translation.abbreviation %></span>
                </div>
                <p class="text-sm font-serif text-stone-600 dark:text-stone-400">
                  <%= highlight(pt.text, @query, highlighter: '<span class="bg-amber-200/50 dark:bg-amber-900/50 px-1">\1</span>') %>
                </p>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</div>
